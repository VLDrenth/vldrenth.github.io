---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Vincent Drenth's research notes on statistics, econometrics, and machine learning." } = Astro.props;

const pathname = Astro.url.pathname;
const isHome    = pathname === '/';
const isNotes   = pathname.startsWith('/blog');
const isArchive = pathname.startsWith('/archive');
const isAbout   = pathname.startsWith('/about');
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title}</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.22/dist/katex.min.css">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>
  <header class="site-header">
    <nav class="container-wide nav-inner">
      <a href="/" class="logo" aria-label="Vincent Drenth — home">
        <span class="logo-bracket">[</span>
        <span class="logo-text">vld</span>
        <span class="logo-bracket">]</span>
      </a>
      <div class="nav-links">
        <a href="/"        class:list={['nav-link', { active: isHome }]}>home</a>
        <a href="/blog"    class:list={['nav-link', { active: isNotes }]}>notes</a>
        <a href="/archive" class:list={['nav-link', { active: isArchive }]}>archive</a>
        <a href="/about"   class:list={['nav-link', { active: isAbout }]}>about</a>
        <a href="https://github.com/vldrenth" target="_blank" rel="noopener" class="nav-link">github&nbsp;↗</a>
      </div>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container-wide footer-inner">
      <div class="footer-copy">
        <span class="footer-thanks">Thanks for reading.</span>
        <span class="footer-year">&copy; {new Date().getFullYear()} Vincent Drenth</span>
      </div>
      <div class="footer-right">
        <div class="footer-icons">
          <a href="https://github.com/vldrenth" target="_blank" rel="noopener" class="footer-icon-link" aria-label="GitHub">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
          <a href="https://linkedin.com/in/vincentdrenth" target="_blank" rel="noopener" class="footer-icon-link" aria-label="LinkedIn">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
        <img src="/signature-sparkline.svg" width="80" height="20" alt="" class="footer-sparkline" />
      </div>
    </div>
  </footer>

  <style>
    .site-header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(246, 241, 232, 0.85);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--rule);
      padding: 14px 0;
    }

    .nav-inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .logo {
      font-family: var(--font-mono);
      font-size: 1.25rem;
      font-weight: 600;
      text-decoration: none;
      display: flex;
      gap: 0;
      background-image: none;
    }

    .logo:hover {
      text-decoration: none;
    }

    .logo-bracket {
      color: var(--ink-3);
      transition: color var(--dur-1) var(--ease-out);
    }

    .logo-text {
      color: var(--rust);
    }

    .logo:hover .logo-bracket {
      color: var(--ink-2);
    }

    .nav-links {
      display: flex;
      gap: 24px;
      font-family: var(--font-mono);
      font-size: 0.875rem;
    }

    .nav-link {
      color: var(--ink-2);
      text-decoration: none;
      background-image: none;
      padding-bottom: 2px;
      border-bottom: 1px solid transparent;
      transition: color var(--dur-1) var(--ease-out),
                  border-color var(--dur-1) var(--ease-out);
    }

    .nav-link:hover {
      color: var(--rust);
      text-decoration: none;
      border-bottom-color: transparent;
    }

    .nav-link.active {
      color: var(--ink);
      border-bottom: 1px solid var(--rust);
    }

    main {
      min-height: calc(100vh - 160px);
      padding: 2rem 0;
    }

    .site-footer {
      border-top: 1px solid var(--rule);
      margin-top: var(--s-9);
      padding: var(--s-6) 0 var(--s-7);
    }

    .footer-inner {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: var(--s-4);
    }

    .footer-copy {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .footer-thanks {
      font-family: var(--font-mono);
      font-size: 0.8125rem;
      color: var(--ink-3);
    }

    .footer-year {
      font-family: var(--font-mono);
      font-size: 0.6875rem;
      color: var(--ink-3);
      opacity: 0.7;
    }

    .footer-right {
      display: flex;
      align-items: center;
      gap: var(--s-5);
    }

    .footer-icons {
      display: flex;
      gap: var(--s-4);
      align-items: center;
    }

    .footer-icon-link {
      color: var(--ink-3);
      background-image: none;
      display: flex;
      transition: color var(--dur-1) var(--ease-out);
    }

    .footer-icon-link:hover {
      color: var(--rust);
    }

    .footer-sparkline {
      border: none;
      border-radius: 0;
    }

    @media (max-width: 768px) {
      .nav-links {
        gap: 16px;
        font-size: 0.8125rem;
      }
    }
  </style>
</body>
</html>
