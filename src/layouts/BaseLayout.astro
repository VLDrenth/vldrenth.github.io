---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Vincent Drenth's research notes on statistics, econometrics, and machine learning." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{title}</title>

  <!-- KaTeX CSS for math rendering -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.22/dist/katex.min.css">

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
</head>
<body>
  <header class="site-header">
    <nav class="container">
      <a href="/" class="logo">
        <span class="logo-bracket">[</span>
        <span class="logo-text">vld</span>
        <span class="logo-bracket">]</span>
      </a>
      <div class="nav-links">
        <a href="/">home</a>
        <a href="/blog">notes</a>
        <a href="https://github.com/vldrenth" target="_blank" rel="noopener">github</a>
      </div>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer class="site-footer">
    <div class="container">
      <p class="footer-text">
        Thanks for reading
      </p>
      <p class="footer-copy">
        &copy; {new Date().getFullYear()} Vincent Drenth
      </p>
    </div>
  </footer>

  <style>
    .site-header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(15, 13, 11, 0.9);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      padding: 1rem 0;
    }

    .site-header nav {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .logo {
      font-family: var(--font-mono);
      font-size: 1.25rem;
      font-weight: 600;
      text-decoration: none;
      display: flex;
      gap: 0;
    }

    .logo:hover {
      text-decoration: none;
    }

    .logo-bracket {
      color: var(--text-muted);
      transition: color 0.2s ease;
    }

    .logo-text {
      color: var(--accent-rust);
      transition: text-shadow 0.2s ease;
    }

    .logo:hover .logo-bracket {
      color: var(--accent-amber);
    }

    .logo:hover .logo-text {
      text-shadow: 0 0 10px var(--accent-rust);
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      font-family: var(--font-mono);
      font-size: 0.9rem;
    }

    .nav-links a {
      color: var(--text-secondary);
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .nav-links a:hover {
      color: var(--accent-rust);
      text-decoration: none;
    }

    main {
      min-height: calc(100vh - 200px);
      padding: 2rem 0;
    }

    .site-footer {
      border-top: 1px solid rgba(255, 255, 255, 0.05);
      padding: 3rem 0;
      margin-top: 4rem;
    }

    .footer-text {
      font-family: var(--font-mono);
      font-size: 0.9rem;
      color: var(--text-muted);
      margin: 0;
    }

    .footer-text .mono {
      color: var(--accent-rust);
    }

    .footer-copy {
      font-size: 0.8rem;
      color: var(--text-muted);
      margin: 0.5rem 0 0 0;
      opacity: 0.6;
    }

    @media (max-width: 768px) {
      .nav-links {
        gap: 1rem;
        font-size: 0.85rem;
      }
    }
  </style>
</body>
</html>
