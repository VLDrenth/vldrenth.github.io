---
import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    subtitle?: string;
    date: string;
    tags?: string[];
    categories?: string[];
  };
}

const { frontmatter } = Astro.props;
const formattedDate = new Date(frontmatter.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});
---

<BaseLayout title={`${frontmatter.title} | Vincent Drenth`} description={frontmatter.subtitle}>
  <article class="container blog-post">
    <header class="post-header">
      <div class="post-meta">
        <time datetime={frontmatter.date} class="post-date">{formattedDate}</time>
        {frontmatter.categories && frontmatter.categories.length > 0 && (
          <span class="categories">
            {frontmatter.categories.map((cat: string) => (
              <span class="category-chip">{cat}</span>
            ))}
          </span>
        )}
      </div>
      <h1 class="post-title">{frontmatter.title}</h1>
      {frontmatter.subtitle && (
        <p class="post-subtitle">{frontmatter.subtitle}</p>
      )}
      {frontmatter.tags && frontmatter.tags.length > 0 && (
        <div class="post-tags">
          {frontmatter.tags.map((tag: string) => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="post-content">
      <slot />
    </div>

    <footer class="post-footer">
      <a href="/blog" class="back-link">&larr; Back to notes</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .blog-post {
    padding-top: var(--s-6);
  }

  .post-header {
    margin-bottom: var(--s-7);
    padding-bottom: var(--s-5);
    border-bottom: 1px solid var(--rule);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--s-3);
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    margin-bottom: 14px;
  }

  .post-date {
    color: var(--amber);
    font-variant-numeric: oldstyle-nums;
  }

  .categories {
    display: flex;
    gap: var(--s-2);
  }

  .category-chip {
    padding: 2px 6px;
    background: var(--paper-2);
    border-radius: var(--r-1);
    font-size: 0.625rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-label);
    color: var(--ink-3);
  }

  .post-title {
    font-size: var(--fs-2xl);
    line-height: var(--lh-tight);
    letter-spacing: var(--tracking-tight);
    font-weight: 600;
    margin: 0 0 var(--s-3);
    color: var(--ink);
    margin-top: 0;
  }

  .post-subtitle {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--ink-2);
    font-style: italic;
    margin: 0 0 var(--s-4);
    line-height: var(--lh-snug);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    margin-top: var(--s-3);
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--amber);
    opacity: 0.85;
  }

  .post-content {
    font-family: var(--font-serif);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--ink);
  }

  .post-content :global(h2) {
    font-size: var(--fs-xl);
    color: var(--rust);
    letter-spacing: var(--tracking-snug);
    margin-top: var(--s-8);
  }

  .post-content :global(h2:first-child) {
    margin-top: 0;
  }

  .post-content :global(h3) {
    font-size: var(--fs-lg);
    margin-top: var(--s-7);
    color: var(--ink);
  }

  .post-footer {
    margin-top: var(--s-7);
    padding-top: var(--s-5);
    border-top: 1px solid var(--rule);
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--ink-2);
    text-decoration: none;
    transition: color var(--dur-1) var(--ease-out);
  }

  .back-link:hover {
    color: var(--rust);
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .post-title {
      font-size: 2rem;
    }

    .post-subtitle {
      font-size: 1.1rem;
    }
  }
</style>
