---
import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    subtitle?: string;
    date: string;
    tags?: string[];
    categories?: string[];
  };
}

const { frontmatter } = Astro.props;
const formattedDate = new Date(frontmatter.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<BaseLayout title={`${frontmatter.title} | Vincent Drenth`} description={frontmatter.subtitle}>
  <article class="container blog-post">
    <header class="post-header">
      <div class="post-meta">
        <time datetime={frontmatter.date}>{formattedDate}</time>
        {frontmatter.categories && frontmatter.categories.length > 0 && (
          <span class="categories">
            {frontmatter.categories.map((cat) => (
              <span class="category">{cat}</span>
            ))}
          </span>
        )}
      </div>
      <h1 class="post-title">{frontmatter.title}</h1>
      {frontmatter.subtitle && (
        <p class="post-subtitle">{frontmatter.subtitle}</p>
      )}
      {frontmatter.tags && frontmatter.tags.length > 0 && (
        <div class="post-tags">
          {frontmatter.tags.map((tag) => (
            <span class="tag">#{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="post-content">
      <slot />
    </div>

    <footer class="post-footer">
      <a href="/blog" class="back-link">
        <span class="arrow">&larr;</span> Back to notes
      </a>
    </footer>
  </article>
</BaseLayout>

<style>
  .blog-post {
    padding-top: 2rem;
  }

  .post-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .post-meta time {
    color: var(--accent-rust);
  }

  .categories {
    display: flex;
    gap: 0.5rem;
  }

  .category {
    padding: 0.15rem 0.5rem;
    background: var(--bg-elevated);
    border-radius: 4px;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .post-title {
    font-size: 2.5rem;
    margin: 0 0 0.5rem 0;
    line-height: 1.2;
    background: linear-gradient(135deg, var(--text-primary), var(--accent-rust));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .post-subtitle {
    font-size: 1.25rem;
    color: var(--text-secondary);
    font-style: italic;
    margin: 0.5rem 0 1rem 0;
    font-family: var(--font-body);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent-amber);
    opacity: 0.7;
  }

  .post-content {
    /* Add some breathing room for math blocks */
  }

  .post-content :global(h2) {
    margin-top: 3rem;
  }

  .post-content :global(h2:first-child) {
    margin-top: 0;
  }

  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text-secondary);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    transition: color 0.2s ease;
  }

  .back-link:hover {
    color: var(--accent-rust);
    text-decoration: none;
  }

  .back-link .arrow {
    transition: transform 0.2s ease;
  }

  .back-link:hover .arrow {
    transform: translateX(-3px);
  }

  @media (max-width: 768px) {
    .post-title {
      font-size: 1.75rem;
    }

    .post-subtitle {
      font-size: 1.1rem;
    }
  }
</style>
