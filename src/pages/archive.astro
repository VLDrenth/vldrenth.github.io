---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const items = await getCollection('archive');

const categories = ['ML', 'Stats', 'Econ', 'Software'] as const;
const grouped = categories.map(cat => ({
  name: cat,
  items: items
    .filter(item => item.data.category === cat)
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
})).filter(group => group.items.length > 0);
---

<BaseLayout title="Archive | Vincent Drenth">
  <div class="container">
    <header class="page-header">
      <h1 class="page-title">Archive</h1>
      <p class="page-description">
        Papers, articles, and resources I've found interesting.
      </p>
    </header>

    <div class="archive-content">
      {grouped.length === 0 && (
        <p class="empty-state">Nothing here yet.</p>
      )}
      {grouped.map((group) => (
        <section class="category-section">
          <h2 class="category-title">{group.name}</h2>
          <ul class="items-list">
            {group.items.map((item) => (
              <li class="archive-item">
                <div class="item-row">
                  <a href={item.data.link} target="_blank" rel="noopener" class="item-link">
                    {item.data.title} <span class="external-icon">&#8599;</span>
                  </a>
                  <time class="item-date">
                    {new Date(item.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                  </time>
                </div>
                {item.data.description && (
                  <p class="item-description">{item.data.description}</p>
                )}
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page-header {
    padding: 48px 0 var(--s-7);
    border-bottom: 1px solid var(--rule);
    margin-bottom: var(--s-7);
  }

  .page-title {
    font-size: 2.5rem;
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    margin: 0 0 10px;
    color: var(--ink);
    margin-top: 0;
  }

  .page-description {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    color: var(--ink-2);
    margin: 0;
  }

  .archive-content {
    display: flex;
    flex-direction: column;
    gap: var(--s-7);
    padding-bottom: var(--s-7);
  }

  .category-section {
    /* section */
  }

  .category-title {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-2);
    margin: 0 0 var(--s-4);
    padding-bottom: var(--s-2);
    border-bottom: 1px solid var(--rule);
    /* override global h2 */
    font-size: 0.8125rem !important;
    color: var(--ink-2) !important;
    margin-top: 0 !important;
  }

  .items-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--s-5);
  }

  .archive-item {
    /* item */
  }

  .item-row {
    display: flex;
    align-items: baseline;
    gap: var(--s-3);
    flex-wrap: wrap;
  }

  .item-link {
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--ink);
    text-decoration: none;
    line-height: 1.5;
    transition: color var(--dur-1) var(--ease-out);
  }

  .item-link:hover {
    color: var(--rust);
    text-decoration: none;
  }

  .external-icon {
    color: var(--ink-3);
    font-size: 0.75rem;
    transition: color var(--dur-1) var(--ease-out);
  }

  .item-link:hover .external-icon {
    color: var(--rust);
  }

  .item-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--ink-3);
    margin-left: auto;
    white-space: nowrap;
    font-variant-numeric: oldstyle-nums;
  }

  .item-description {
    font-family: var(--font-serif);
    font-size: 0.9375rem;
    color: var(--ink-2);
    margin: 6px 0 0;
    line-height: 1.5;
  }

  .empty-state {
    color: var(--ink-3);
    font-style: italic;
    font-family: var(--font-serif);
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: 2rem;
    }

    .item-date {
      margin-left: 0;
    }
  }
</style>
