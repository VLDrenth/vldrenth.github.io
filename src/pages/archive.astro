---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const items = await getCollection('archive');

// Group by category
const categories = ['ML', 'Stats', 'Econ', 'Software'] as const;
const grouped = categories.map(cat => ({
  name: cat,
  items: items
    .filter(item => item.data.category === cat)
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
})).filter(group => group.items.length > 0);
---

<BaseLayout title="Archive | Vincent Drenth">
  <div class="container">
    <header class="page-header">
      <h1 class="page-title">Archive</h1>
      <p class="page-description">
        Papers, articles, and resources I've found interesting.
      </p>
    </header>

    <div class="archive-content">
      {grouped.length === 0 && (
        <p class="empty-state">Nothing here yet.</p>
      )}
      {grouped.map((group) => (
        <section class="category-section">
          <h2 class="category-title">{group.name}</h2>
          <ul class="items-list">
            {group.items.map((item) => (
              <li class="archive-item">
                <a href={item.data.link} target="_blank" rel="noopener" class="item-link">
                  <span class="item-title">{item.data.title}</span>
                  <span class="external-icon">↗</span>
                </a>
                {item.data.description && (
                  <p class="item-description">{item.data.description}</p>
                )}
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page-header {
    padding: 3rem 0 4rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    margin-bottom: 3rem;
  }

  .page-title {
    font-size: 2.5rem;
    margin: 0 0 1rem 0;
    background: linear-gradient(135deg, var(--text-primary), var(--accent-rust));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .page-description {
    color: var(--text-secondary);
    font-size: 1.1rem;
    margin: 0;
    max-width: 500px;
  }

  .archive-content {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .category-section {
    /* section styling */
  }

  .category-title {
    font-size: 1.1rem;
    margin: 0 0 1.25rem 0;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .items-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .archive-item {
    /* item styling */
  }

  .item-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--text-primary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .item-link:hover {
    color: var(--accent-rust);
    text-decoration: none;
  }

  .external-icon {
    font-size: 0.8rem;
    color: var(--text-muted);
    transition: color 0.2s ease;
  }

  .item-link:hover .external-icon {
    color: var(--accent-rust);
  }

  .item-description {
    margin: 0.25rem 0 0 0;
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .empty-state {
    color: var(--text-muted);
    font-style: italic;
  }

  @media (max-width: 768px) {
    .page-title {
      font-size: 2rem;
    }
  }
</style>
