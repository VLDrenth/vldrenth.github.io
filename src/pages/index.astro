---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts
  .filter(post => post.data.published !== false)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<BaseLayout title="Vincent Drenth">
  <div class="container">
    <section class="hero">
      <h1 class="hero-name">Vincent Drenth</h1>
      <p class="hero-tagline">
        statistics <span class="dot">&middot;</span>
        econometrics <span class="dot">&middot;</span>
        <span class="tagline-accent">machine learning</span>
      </p>
      <p class="hero-description">
        This site is a place to write up or archive anything I find interesting enough to share or keep.
      </p>
      <img src="/wavy-rule.svg" class="hero-rule" width="140" height="12" alt="" />
    </section>

    <section class="recent-posts">
      <h2 class="section-heading">Recent Notes</h2>
      <div class="posts-grid">
        {sortedPosts.map((post) => (
          <a href={`/blog/${post.id}`} class="post-card">
            <div class="post-card-meta">
              <time class="post-date">
                {new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
              </time>
              {post.data.categories && (
                <span class="card-category">{post.data.categories[0]}</span>
              )}
            </div>
            <div class="post-card-title">{post.data.title}</div>
            {post.data.subtitle && (
              <div class="post-card-subtitle">{post.data.subtitle}</div>
            )}
            <span class="read-more">Read &rarr;</span>
          </a>
        ))}
      </div>
      <a href="/blog" class="view-all">View all notes &rarr;</a>
    </section>
  </div>
</BaseLayout>

<style>
  .hero {
    padding: 72px 0 40px;
  }

  .hero-name {
    font-size: var(--fs-3xl);
    line-height: 1.05;
    letter-spacing: -0.02em;
    font-weight: 600;
    margin: 0 0 20px;
    color: var(--ink);
    margin-top: 0;
  }

  .hero-tagline {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--ink-2);
    margin: 0 0 var(--s-5);
    line-height: 1.5;
  }

  .dot {
    color: var(--ink-3);
    margin: 0 2px;
  }

  .tagline-accent {
    color: var(--rust);
  }

  .hero-description {
    font-family: var(--font-serif);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--ink-2);
    margin: 0;
    max-width: 560px;
  }

  .hero-rule {
    display: block;
    margin-top: var(--s-7);
    opacity: 0.7;
    border: none;
    border-radius: 0;
  }

  /* Recent Notes */
  .recent-posts {
    padding: 48px 0;
  }

  .section-heading {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0 0 var(--s-5);
    padding-bottom: var(--s-3);
    border-bottom: 1px solid var(--rule);
  }

  .posts-grid {
    display: grid;
    gap: var(--s-4);
    margin-bottom: var(--s-5);
  }

  .post-card {
    display: block;
    padding: 22px var(--s-5);
    background: var(--paper);
    border: 1px solid var(--rule);
    border-radius: var(--r-2);
    text-decoration: none;
    background-image: none;
    transition: border-color var(--dur-2) var(--ease-out),
                transform var(--dur-2) var(--ease-out),
                box-shadow var(--dur-2) var(--ease-out);
    color: inherit;
  }

  .post-card:hover {
    border-color: var(--rust);
    transform: translateY(-1px);
    box-shadow: var(--shadow-2);
    text-decoration: none;
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: var(--s-3);
    margin-bottom: 10px;
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--amber);
    font-variant-numeric: oldstyle-nums;
  }

  .card-category {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink-3);
    padding: 2px 6px;
    background: var(--paper-2);
    border-radius: var(--r-1);
  }

  .post-card-title {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 6px;
    line-height: var(--lh-snug);
  }

  .post-card-subtitle {
    font-family: var(--font-serif);
    font-size: 0.9375rem;
    color: var(--ink-2);
    font-style: italic;
    margin-bottom: 10px;
    line-height: 1.5;
  }

  .read-more {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--rust);
    opacity: 0.6;
    transition: opacity var(--dur-2) var(--ease-out),
                transform var(--dur-2) var(--ease-out);
  }

  .post-card:hover .read-more {
    opacity: 1;
    transform: translateX(3px);
  }

  .view-all {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-mono);
    font-size: 0.875rem;
    color: var(--ink-2);
    text-decoration: none;
    transition: color var(--dur-1) var(--ease-out);
  }

  .view-all:hover {
    color: var(--rust);
    text-decoration: none;
  }

  @media (max-width: 768px) {
    .hero-name {
      font-size: 2.5rem;
    }

    .hero {
      padding: 48px 0 32px;
    }
  }
</style>
