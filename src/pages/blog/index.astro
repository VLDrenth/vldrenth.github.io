---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
const sortedPosts = posts
  .filter(post => post.data.published !== false)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout title="Notes | Vincent Drenth">
  <div class="container">
    <header class="page-header">
      <h1 class="page-title">Notes</h1>
      <p class="page-description">
        Research notes, derivations, and explorations in statistics and related fields.
      </p>
    </header>

    <div class="posts-list">
      {sortedPosts.map((post) => (
        <a href={`/blog/${post.id}`} class="post-item">
          <time class="post-date" datetime={post.data.date}>
            {new Date(post.data.date).toLocaleDateString('en-US', {
              month: 'short',
              day: 'numeric',
              year: 'numeric'
            })}
          </time>
          <div class="post-body">
            <div class="post-title">{post.data.title}</div>
            {post.data.subtitle && (
              <div class="post-subtitle">{post.data.subtitle}</div>
            )}
            <div class="post-chips">
              {post.data.categories && post.data.categories.map((cat: string) => (
                <span class="category-chip">{cat}</span>
              ))}
              {post.data.tags && post.data.tags.slice(0, 3).map((tag: string) => (
                <span class="tag-chip">#{tag}</span>
              ))}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page-header {
    padding: 48px 0 40px;
    border-bottom: 1px solid var(--rule);
    margin-bottom: var(--s-7);
  }

  .page-title {
    font-size: 2.5rem;
    font-weight: 600;
    letter-spacing: var(--tracking-tight);
    margin: 0 0 10px;
    color: var(--ink);
    margin-top: 0;
  }

  .page-description {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    color: var(--ink-2);
    margin: 0;
    max-width: 500px;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
  }

  .post-item {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: var(--s-5);
    padding: var(--s-5) 0;
    border-bottom: 1px solid var(--rule);
    text-decoration: none;
    background-image: none;
    color: inherit;
    transition: background var(--dur-2) var(--ease-out);
  }

  .post-item:last-child {
    border-bottom: none;
  }

  .post-item:hover {
    text-decoration: none;
  }

  .post-item:hover .post-title {
    color: var(--rust);
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--amber);
    padding-top: 4px;
    font-variant-numeric: oldstyle-nums;
    white-space: nowrap;
  }

  .post-body {
    min-width: 0;
  }

  .post-title {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 4px;
    line-height: var(--lh-snug);
    transition: color var(--dur-1) var(--ease-out);
  }

  .post-subtitle {
    font-family: var(--font-serif);
    font-size: 0.9375rem;
    color: var(--ink-2);
    font-style: italic;
    margin-bottom: var(--s-2);
    line-height: 1.5;
  }

  .post-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s-2);
    margin-top: var(--s-2);
  }

  .category-chip {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: var(--tracking-label);
    text-transform: uppercase;
    color: var(--ink-3);
    padding: 2px 6px;
    background: var(--paper-2);
    border-radius: var(--r-1);
  }

  .tag-chip {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--amber);
    opacity: 0.85;
  }

  @media (max-width: 600px) {
    .post-item {
      grid-template-columns: 1fr;
      gap: var(--s-2);
    }

    .page-title {
      font-size: 2rem;
    }
  }
</style>
